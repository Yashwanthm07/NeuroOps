{
    "name": "neuro-ops-backend",
    "version": "2.5.0",
    "description": "NeuroOps Backend API Server",
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "db:migrate": "ts-node src/db/migrate.ts",
        "db:seed": "ts-node src/db/seed.ts",
        "test": "jest",
        "test:watch": "jest --watch",
        "lint": "eslint src --ext .ts",
        "format": "prettier --write src"
    },
    "dependencies": {
        "express": "^4.18.2",
        "cors": "^2.8.5",
        "pg": "^8.11.3",
        "pg-format": "^1.0.4",
        "redis": "^4.6.12",
        "axios": "^1.6.0",
        "dotenv": "^16.3.1",
        "uuid": "^9.0.1",
        "pino": "^8.17.2",
        "pino-http": "^8.6.1",
        "jsonwebtoken": "^8.5.1",
        "joi": "^17.11.0",
        "helmet": "^7.1.0",
        "express-rate-limit": "^7.1.5",
        "bull": "^4.12.0",
        "node-cron": "^3.0.3",
        "graphology": "^0.25.4",
        "graphology-shortest-path": "^2.0.2",
        "ioredis": "^5.3.2",
        "ethers": "^6.10.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.0",
        "@types/jest": "^29.5.11",
        "@typescript-eslint/eslint-plugin": "^6.13.2",
        "@typescript-eslint/parser": "^6.13.2",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.1",
        "prettier": "^3.1.0",
        "eslint": "^8.55.0"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    }
}