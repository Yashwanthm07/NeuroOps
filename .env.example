# NeuroOps Configuration

# Server
NODE_ENV=development
PORT=3000
API_HOST=localhost
API_PORT=3001

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=neuro_ops
DB_USER=neuro_admin
DB_PASSWORD=secure_password_change_me
DB_SSL=false

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_pass
REDIS_DB=0

# Claude AI
CLAUDE_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=1000

# Observability Stack
PROMETHEUS_HOST=prometheus
PROMETHEUS_PORT=9090
LOKI_HOST=loki
LOKI_PORT=3100
JAEGER_HOST=jaeger
JAEGER_PORT=6831

# Feature Flags
ENABLE_CLAUDE_AI=true
ENABLE_CAUSAL_ANALYSIS=true
ENABLE_AUTO_REMEDIATION=true
ENABLE_GRAPH_LEARNING=true
CONFIDENCE_THRESHOLD=75
SLO_THRESHOLD_MS=15000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Security
JWT_SECRET=your_jwt_secret_change_me
JWT_EXPIRY=7d

# Incident Detection
INCIDENT_DETECTION_INTERVAL=5000
ANOMALY_THRESHOLD=0.75
METRIC_WINDOW_SIZE=300000

# Remediation
REMEDIATION_TIMEOUT=30000
PLAYBOOK_REGISTRY_URL=http://playbook-registry:3000

# Integrations
DOCKER_API_URL=unix:///var/run/docker.sock
KUBERNETES_ENABLED=false
KUBERNETES_NAMESPACE=default

# Monitoring
METRICS_PORT=9091
ENABLE_PROFILING=false
TRACE_SAMPLE_RATE=0.1
